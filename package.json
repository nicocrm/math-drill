{
  "name": "math-drill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "dev": "concurrently -n ui,api,worker -c cyan,green,yellow \"vite\" \"pnpm exec tsx --watch server/api.ts\" \"pnpm exec tsx --watch server/worker.ts\"",
    "dev:ui": "vite",
    "build": "vite build",
    "build:server": "esbuild server/api.ts server/worker.ts --bundle --platform=node --target=node22 --format=esm --outdir=dist/server --packages=external",
    "build:all": "pnpm run build && pnpm run build:server",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "start:api": "node dist/server/api.js",
    "start:worker": "node dist/server/worker.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@clerk/react": "^6.1.0",
    "@math-drill/core": "workspace:*",
    "bullmq": "^5.76.1",
    "express": "^5.1.0",
    "ioredis": "^5.10.1",
    "katex": "^0.16.37",
    "mathjs": "^15.1.1",
    "openai": "^6.27.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-router": "^7.13.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "multer": "^2.1.1",
    "postcss": "^8",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "@emnapi/core": "1.10.0",
      "@emnapi/runtime": "1.10.0"
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}

{
  "name": "math-drill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "INGEST_WORKER_URL=http://localhost:3002 concurrently -n ui,api -c cyan,green \"vite\" \"npx tsx --watch functions/dev-server.ts\"",
    "dev:ui": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev:api": "INGEST_WORKER_URL=http://localhost:3002 npx tsx --watch functions/dev-server.ts",
    "dev:worker": "npx tsx --watch functions/dev-worker.ts",
    "smoke:functions": "bash scripts/smoke-test-functions.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.1009.0",
    "@clerk/react": "^6.1.0",
    "@math-drill/core": "*",
    "express": "^5.1.0",
    "katex": "^0.16.37",
    "mathjs": "^15.1.1",
    "openai": "^6.27.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-router": "^7.13.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.7.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}

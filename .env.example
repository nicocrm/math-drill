# Dump raw LLM output to /tmp on JSON parse failure (default: false)
DEBUG_LLM_OUTPUT=false

EXTRACTION_PROVIDER=anthropic

# Verify explanations for hallucination (default: true). Set to false to skip verification.
VERIFY_EXPLANATIONS=true

# Required when EXTRACTION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Required when EXTRACTION_PROVIDER=openai
OPENAI_API_KEY=sk-...

EXERCISES_DIR=./exercises
INTAKE_DIR=./intake

# BullMQ (local: docker compose up -d for redis:7-alpine on 6379)
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=3

# Clerk authentication (https://clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# JWT public key for networkless token verification (required for local dev when JWKS fetch fails).
# Get from: Clerk Dashboard → API Keys → Show JWT public key → PEM Public Key
CLERK_JWT_KEY=

# S3 (Scaleway Object Storage or other S3-compatible). Omit for local disk storage.
# STORAGE=s3
# S3_BUCKET=your-bucket
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_REGION=fr-par
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
